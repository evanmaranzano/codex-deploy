{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Deploy",
  "version": "0.1.0",
  "identifier": "com.evanmaranzano.codex-deploy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Deploy",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [
      "resources/third_party"
    ],
    "icon": []
  }
}
